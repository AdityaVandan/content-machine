# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Model to use via OpenRouter (default: anthropic/claude-opus-4-5)
# OPENROUTER_MODEL=anthropic/claude-opus-4-5

# Buffer (https://buffer.com/developers/apps → create app → get access token)
BUFFER_ACCESS_TOKEN=...

# Buffer profile IDs — get them by running:
#   curl -H "Authorization: Bearer YOUR_TOKEN" https://api.bufferapp.com/1/profiles.json
# and look for the "id" field for each connected profile
BUFFER_TWITTER_PROFILE_ID=
BUFFER_LINKEDIN_PROFILE_ID=
